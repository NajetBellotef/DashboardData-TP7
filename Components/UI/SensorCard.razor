@using DashboardData.Models

<div class="card shadow-sm h-100">
    <div class="card-body d-flex justify-content-between align-items-center">

        <!-- Partie gauche -->
        <div>
            <h5 class="card-title">@Sensor.Name</h5>
            <h6 class="text-muted">
                @(Sensor.Location?.Name ?? "Lieu inconnu")
            </h6>

            <p class="mt-2 mb-0">
                <strong>@Sensor.Value °C</strong>
            </p>
        </div>

        <!-- Icône -->
        <div>
            <i class="bi bi-thermometer-half text-primary"
               style="font-size: 2.5rem;"></i>
        </div>

    </div>
</div>

@code {
    [Parameter]
    public SensorData Sensor { get; set; } = new();
}