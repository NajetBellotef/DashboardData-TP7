@page "/add-sensor"
@using DashboardData.Models
@using DashboardData.Services
@inject ISensorService SensorService
@inject NavigationManager NavManager



<h3>Ajouter un nouveau capteur</h3>

<div class="card p-3 shadow-sm" style="max-width: 400px;">
    <div class="mb-3">
        <label class="form-label">Nom du capteur</label>
        <input type="text" class="form-control" @bind="newSensorName" placeholder="Ex: Temp_Cuisine" />
    </div>
    <div class="mb-3">
        <label class="form-label">Valeur initiale</label>
        <input type="number" class="form-control" @bind="newSensorValue" />
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-success" @onclick="SaveSensor">Enregistrer</button>
        <button class="btn btn-secondary" @onclick="Cancel">Annuler</button>
    </div>
</div>

@code {
    private string newSensorName = "";
    private double newSensorValue = 0;

    private async Task SaveSensor()
    {
        if (!string.IsNullOrWhiteSpace(newSensorName))
        {
            // 1. On crée l'objet capteur
           var newSensor = new SensorData
{
    Name = newSensorName,
    Value = newSensorValue,
    LocationId = 1
};
            await SensorService.AddSensorAsync(newSensor);
 
            NavManager.NavigateTo("/dashboard", true);
        }
    }

    private void Cancel()
    {
        NavManager.NavigateTo("/dashboard");
    }
    

    
}