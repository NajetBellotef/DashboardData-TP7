@page "/converter"
@rendermode InteractiveServer

<PageTitle>Convertisseur</PageTitle>

<h3>Convertisseur de Température</h3>

<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label">Fahrenheit :</label>
        <input type="number" class="form-control" @bind="tempF" @bind:event="oninput" />
        <div class="mt-2 alert alert-info">
            Résultat : <strong>@Celsius.ToString("F2")</strong> °C
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <label class="form-label">Celsius :</label>
        <input type="number" class="form-control" @bind="tempC" @bind:event="oninput" />
        <div class="mt-2 alert alert-success">
            Résultat : <strong>@Fahrenheit.ToString("F2")</strong> °F
        </div>
    </div>
</div>

@code {
    private double tempF = 100;
    private double tempC = 0;

    private double Celsius => (tempF - 32) * 5 / 9;

    // Formule inverse : (Celsius * 9/5) + 32
    private double Fahrenheit => (tempC * 9 / 5) + 32;
}